# Notionインテグレーションのシークレットキー
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NotionのデータベースID（URLから取得）
NOTION_LUNCH_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_NEWS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_HOLIDAY_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_RECIPE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram Graph API（リール自動取得）
# 取得方法: https://developers.facebook.com/docs/instagram-api/getting-started
# ※ 長期トークン（60日有効）。期限前に /api/instagram/refresh を呼ぶと更新できます
INSTAGRAM_ACCESS_TOKEN=IGAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
